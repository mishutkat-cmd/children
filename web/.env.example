# Kids Motivation — Frontend (скопируйте в .env.local и заполните при необходимости)
# Локальная разработка: обычно не нужен — API по умолчанию http://localhost:3000

# URL бэкенда (только для разработки или если фронт и API на разных доменах)
# Для продакшена, когда фронт раздаётся тем же бэкендом — оставьте пустым или не задавайте
VITE_API_URL=

# Пример для разработки с другим портом:
# VITE_API_URL=http://localhost:3000

# Пример если API на отдельном домене:
# VITE_API_URL=https://api.example.com
