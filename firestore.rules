rules_version = '2';

// All data access goes through the NestJS backend, which uses the
// Admin SDK and bypasses these rules. Web/mobile clients do NOT
// talk to Firestore directly. So deny everything from client SDKs
// by default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
