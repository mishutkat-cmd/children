# Kids Motivation — Backend (скопируйте в .env и заполните)
# Локальная разработка: скопируйте этот файл в backend/.env

# JWT (обязательно)
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Порт: 3000 для локальной разработки. На продакшене (ISPmanager) НЕ указывать PORT в .secrets — хостинг задаёт путь к сокету
PORT=3000

# Frontend (если бэкенд раздаёт SPA)
FRONTEND_ENABLED=true
FRONTEND_BUILD_PATH=

# Путь к собранному фронту относительно backend/ или абсолютный:
# FRONTEND_BUILD_PATH=../web/dist

# Firebase (для Firestore и Storage) — проект childrenevolvenext
# Credentials ДОЛЖНЫ быть от childrenevolvenext (project_id в JSON)
# Вариант 1: путь к JSON ключу сервисного аккаунта
# FIREBASE_SA_PATH=./childrenevolvenext-firebase-adminsdk-xxx.json
# Вариант 2: на продакшене — в .secrets
# FIREBASE_SA_PATH=/path/to/.secrets/childrenevolvenext-firebase-sa.json
# Вариант 3: JSON в переменной (для Docker/CI)
# FIREBASE_SA_JSON={"type":"service_account","project_id":"childrenevolvenext",...}

# Storage API (Firestore KV): если задан, POST/GET/DELETE /api/v1/storage требуют x-api-key
# STORAGE_API_KEY=

# На продакшене (children.evolvenext.net): секреты вне проекта
# server.js загружает: 1) backend/.env (или симлинк) 2) /home/.../.secrets/children.env
# FIREBASE_SERVICE_ACCOUNT_PATH — альтернативное имя для FIREBASE_SA_PATH

# Опционально: имя проекта и сайта (для загрузки .env из .secrets)
# PROJECT_NAME=kids-motivation
# SITE_NAME=mysite
